{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "CMake: Configure",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--preset",
                "stm32f411ce-debug"
            ],
            "group": "build",
            "problemMatcher": []
        },
        {
            "label": "CMake: Build",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "--preset",
                "stm32f411ce-debug",
                "--parallel"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": {
                "owner": "cpp",
                "fileLocation": [
                    "absolute"
                ],
                "pattern": {
                    "regexp": "^(.*):(\\d+):(\\d+):\\s+(warning|error):\\s+(.*)$",
                    "file": 1,
                    "line": 2,
                    "column": 3,
                    "severity": 4,
                    "message": 5
                }
            }
        },
        {
            "label": "CMake: Clean",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "--preset",
                "stm32f411ce-debug",
                "--target",
                "clean"
            ],
            "group": "build",
            "problemMatcher": []
        },
        {
            "label": "Flash: OpenOCD",
            "type": "shell",
            "command": "openocd",
            "args": [
                "-f",
                "interface/stlink.cfg",
                "-f",
                "target/stm32f4x.cfg",
                "-c",
                "program build/stm32f411ce-debug/ferrum.elf verify reset exit"
            ],
            "dependsOn": "CMake: Build",
            "group": "build",
            "problemMatcher": []
        },
        {
            "label": "CMake: Cppcheck Quick",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "--preset",
                "stm32f411ce-debug",
                "--target",
                "cppcheck_quick",
                "--parallel"
            ],
            "group": "test",
            "problemMatcher": {
                "owner": "cppcheck",
                "fileLocation": [
                    "absolute"
                ],
                "pattern": {
                    "regexp": "^(.*):(\\d+):(\\d+):\\s+(error|warning|style|performance|portability|information):\\s+(.*)$",
                    "file": 1,
                    "line": 2,
                    "column": 3,
                    "severity": 4,
                    "message": 5
                }
            }
        },
        {
            "label": "CMake: Cppcheck Full",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "--preset",
                "stm32f411ce-debug",
                "--target",
                "cppcheck_full",
                "--parallel"
            ],
            "group": "test",
            "problemMatcher": {
                "owner": "cppcheck",
                "fileLocation": [
                    "absolute"
                ],
                "pattern": {
                    "regexp": "^(.*):(\\d+):(\\d+):\\s+(error|warning|style|performance|portability|information):\\s+(.*)$",
                    "file": 1,
                    "line": 2,
                    "column": 3,
                    "severity": 4,
                    "message": 5
                }
            }
        }
    ]
}