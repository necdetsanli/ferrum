# Force LF line endings for all text files
* text=auto eol=lf

# C source
*.c text eol=lf
*.h text eol=lf

# Assembly
*.s text eol=lf
*.S text eol=lf

# Build files
*.cmake text eol=lf
*.ld text eol=lf
*.lds text eol=lf
CMakeLists.txt text eol=lf

# Config
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.md text eol=lf
*.cfg text eol=lf

# Shell scripts
*.sh text eol=lf
*.cmd text eol=crlf
*.bat text eol=crlf

# Binary - do not modify
*.elf binary
*.bin binary
*.hex binary
*.svd binary
*.pdf binary
*.png binary
*.jpg binary
